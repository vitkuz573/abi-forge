{
  "schema_version": 1,
  "package": "abi_framework.generator_sdk",
  "metadata": {
    "description": "Reusable target-agnostic external generators bundled with abi_framework."
  },
  "plugins": [
    {
      "name": "abi_framework.symbol_contract",
      "version": "1.0.0",
      "description": "Generate symbol contract lockfile from declarative sources.",
      "entrypoint": {
        "kind": "external",
        "command": [
          "python3",
          "{repo_root}/tools/abi_framework/generator_sdk/symbol_contract_generator.py",
          "--idl",
          "{idl}",
          "--spec",
          "{repo_root}/abi/bindings/lumenrtc.symbol_contract.sources.json",
          "--out",
          "{repo_root}/abi/bindings/lumenrtc.symbol_contract.json",
          "{check}",
          "{dry_run}"
        ]
      },
      "capabilities": {
        "supports_check": true,
        "supports_dry_run": true,
        "deterministic_output": true,
        "requires_repo_root": true,
        "writes_managed_sources": false
      },
      "contracts": {
        "inputs": [
          {
            "name": "idl",
            "path_arg": "--idl",
            "required": true
          },
          {
            "name": "symbol_contract_spec",
            "path_arg": "--spec",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "symbol_contract_lockfile",
            "path_arg": "--out",
            "required": true
          }
        ]
      },
      "compatibility": {
        "min_idl_schema_version": 1,
        "max_idl_schema_version": 1
      },
      "diagnostics": {
        "codes": [
          "ABIGENSDK001"
        ]
      },
      "owners": [
        "@vitkuz573"
      ]
    },
    {
      "name": "abi_framework.native_exports",
      "version": "1.0.0",
      "description": "Generate native ABI export forwarding stubs and impl header from IDL. Works for any C library.",
      "entrypoint": {
        "kind": "external",
        "command": [
          "python3",
          "{repo_root}/tools/abi_framework/generator_sdk/native_exports_generator.py",
          "--idl", "{idl}",
          "--out", "{repo_root}/native/src/{target}.exports.cpp",
          "--impl-header", "{repo_root}/native/src/{target}_impl.h",
          "{check}",
          "{dry_run}"
        ]
      },
      "capabilities": {
        "supports_check": true,
        "supports_dry_run": true,
        "deterministic_output": true,
        "requires_repo_root": true,
        "writes_managed_sources": false
      },
      "contracts": {
        "inputs": [{"name": "idl", "path_arg": "--idl", "required": true}],
        "outputs": [
          {"name": "exports_cpp", "path_arg": "--out"},
          {"name": "impl_header", "path_arg": "--impl-header"}
        ]
      },
      "compatibility": {
        "min_idl_schema_version": 1,
        "max_idl_schema_version": 1
      },
      "owners": ["@vitkuz573"]
    },
    {
      "name": "abi_framework.managed_api_metadata",
      "version": "1.0.0",
      "description": "Normalize managed_api.source.json and derive required_native_functions from IDL. Works for any .NET wrapper.",
      "entrypoint": {
        "kind": "external",
        "command": [
          "python3",
          "{repo_root}/tools/abi_framework/generator_sdk/managed_api_metadata_generator.py",
          "--idl", "{idl}",
          "--source", "{repo_root}/abi/bindings/{target}.managed_api.source.json",
          "--out", "{repo_root}/abi/bindings/{target}.managed_api.json",
          "{check}",
          "{dry_run}"
        ]
      },
      "capabilities": {
        "supports_check": true,
        "supports_dry_run": true,
        "deterministic_output": true,
        "requires_repo_root": true,
        "writes_managed_sources": false
      },
      "contracts": {
        "inputs": [
          {"name": "idl", "path_arg": "--idl", "required": true},
          {"name": "managed_api_source", "path_arg": "--source", "required": true}
        ],
        "outputs": [
          {"name": "managed_api_json", "path_arg": "--out", "required": true}
        ]
      },
      "compatibility": {
        "min_idl_schema_version": 1,
        "max_idl_schema_version": 1
      },
      "owners": ["@vitkuz573"]
    },
    {
      "name": "abi_framework.managed_api_scaffold",
      "version": "1.0.0",
      "description": "Scaffold a managed_api.source.json from IDL. Run once when adding a new library target.",
      "entrypoint": {
        "kind": "external",
        "command": [
          "python3",
          "{repo_root}/tools/abi_framework/generator_sdk/managed_api_scaffold_generator.py",
          "--idl", "{idl}",
          "--namespace", "TODO_NAMESPACE",
          "--out", "{repo_root}/abi/bindings/{target}.managed_api.source.json",
          "{check}",
          "{dry_run}"
        ]
      },
      "capabilities": {
        "supports_check": true,
        "supports_dry_run": true,
        "deterministic_output": true,
        "requires_repo_root": true,
        "writes_managed_sources": false
      },
      "contracts": {
        "inputs": [{"name": "idl", "path_arg": "--idl", "required": true}],
        "outputs": [
          {"name": "managed_api_source", "path_arg": "--out", "required": true}
        ]
      },
      "compatibility": {
        "min_idl_schema_version": 1,
        "max_idl_schema_version": 1
      },
      "owners": ["@vitkuz573"]
    },
    {
      "name": "abi_framework.managed_bindings_scaffold",
      "version": "1.0.0",
      "description": "Scaffold managed.json (SafeHandle definitions) from IDL opaque_types. Run once per target.",
      "entrypoint": {
        "kind": "external",
        "command": [
          "python3",
          "{repo_root}/tools/abi_framework/generator_sdk/managed_bindings_scaffold_generator.py",
          "--idl", "{idl}",
          "--namespace", "TODO_NAMESPACE",
          "--out", "{repo_root}/abi/bindings/{target}.managed.json",
          "{check}",
          "{dry_run}"
        ]
      },
      "capabilities": {
        "supports_check": true,
        "supports_dry_run": true,
        "deterministic_output": true,
        "requires_repo_root": true,
        "writes_managed_sources": false
      },
      "contracts": {
        "inputs": [{"name": "idl", "path_arg": "--idl", "required": true}],
        "outputs": [{"name": "managed_bindings", "path_arg": "--out", "required": true}]
      },
      "compatibility": {
        "min_idl_schema_version": 1,
        "max_idl_schema_version": 1
      },
      "owners": ["@vitkuz573"]
    },
    {
      "name": "abi_framework.python_bindings",
      "version": "1.0.0",
      "description": "Generate Python ctypes bindings from IDL. Works for any C library.",
      "entrypoint": {
        "kind": "external",
        "command": [
          "python3",
          "{repo_root}/tools/abi_framework/generator_sdk/python_bindings_generator.py",
          "--idl", "{idl}",
          "--out", "{repo_root}/abi/generated/{target}/{target}_ctypes.py",
          "{check}",
          "{dry_run}"
        ]
      },
      "capabilities": {
        "supports_check": true,
        "supports_dry_run": true,
        "deterministic_output": true,
        "requires_repo_root": true,
        "writes_managed_sources": false
      },
      "contracts": {
        "inputs": [{"name": "idl", "path_arg": "--idl", "required": true}],
        "outputs": [{"name": "python_bindings", "path_arg": "--out", "required": true}]
      },
      "compatibility": {
        "min_idl_schema_version": 1,
        "max_idl_schema_version": 1
      },
      "owners": ["@vitkuz573"]
    },
    {
      "name": "abi_framework.rust_ffi",
      "version": "1.0.0",
      "description": "Generate Rust FFI bindings from IDL. Works for any C library.",
      "entrypoint": {
        "kind": "external",
        "command": [
          "python3",
          "{repo_root}/tools/abi_framework/generator_sdk/rust_ffi_generator.py",
          "--idl", "{idl}",
          "--out", "{repo_root}/abi/generated/{target}/{target}_ffi.rs",
          "{check}",
          "{dry_run}"
        ]
      },
      "capabilities": {
        "supports_check": true,
        "supports_dry_run": true,
        "deterministic_output": true,
        "requires_repo_root": true,
        "writes_managed_sources": false
      },
      "contracts": {
        "inputs": [{"name": "idl", "path_arg": "--idl", "required": true}],
        "outputs": [{"name": "rust_ffi", "path_arg": "--out", "required": true}]
      },
      "compatibility": {
        "min_idl_schema_version": 1,
        "max_idl_schema_version": 1
      },
      "owners": ["@vitkuz573"]
    }
  ]
}
